---
# Based on ansible-lint config
extends: default

rules:
  braces:
    max-spaces-inside: 1
    level: error
  brackets:
    max-spaces-inside: 1
    level: error
  colons:
    max-spaces-after: -1
    level: error
  commas:
    max-spaces-after: -1
    level: error
  # Must be set to be compatible with `ansible-lint`.
  # See https://docs.ansible.com/projects/lint/rules/yaml/#yamllint-configuration
  comments:
    min-spaces-from-content: 1
    level: warning
  comments-indentation: disable
  document-start:
    present: true
  empty-lines:
    max: 3
    level: error
  hyphens:
    level: error
  indentation: disable
  key-duplicates: enable
  line-length: disable
  new-line-at-end-of-file: disable
  new-lines:
    type: unix
  trailing-spaces: disable
  truthy: disable
  # Must be set to be compatible with `ansible-lint`.
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true

ignore: |
  venv/
